---
// QuestTable is a client-side interactive component
// Data is loaded via fetch in the browser
const base = import.meta.env.BASE_URL;
---

<div id="quest-table-app" data-base={base}>
  <div class="flex flex-col sm:flex-row gap-3 mb-6">
    <div class="flex-1 relative">
      <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input
        id="quest-search"
        type="text"
        placeholder="Search quests..."
        class="w-full bg-midnight-800/60 border border-midnight-600/50 rounded-xl pl-10 pr-4 py-2.5 text-white placeholder-gray-600 focus:outline-none focus:border-arcane-400/50 transition-colors text-sm"
      />
    </div>
    <select
      id="quest-zone-filter"
      class="bg-midnight-800/60 border border-midnight-600/50 rounded-xl px-4 py-2.5 text-gray-300 focus:outline-none focus:border-arcane-400/50 transition-colors text-sm"
    >
      <option value="">All Zones</option>
      <option value="Voidstorm">Voidstorm</option>
      <option value="Eversong Woods">Eversong Woods</option>
      <option value="Zul'Aman">Zul'Aman</option>
      <option value="Harandar">Harandar</option>
    </select>
    <select
      id="quest-type-filter"
      class="bg-midnight-800/60 border border-midnight-600/50 rounded-xl px-4 py-2.5 text-gray-300 focus:outline-none focus:border-arcane-400/50 transition-colors text-sm"
    >
      <option value="">All Types</option>
      <option value="campaign">Campaign</option>
      <option value="sidestory">Side Story</option>
      <option value="important">Important</option>
    </select>
  </div>

  <div class="text-xs text-gray-600 mb-3" id="quest-count"></div>

  <div class="overflow-x-auto bg-midnight-800/30 border border-midnight-600/30 rounded-xl">
    <table class="w-full text-left">
      <thead>
        <tr class="border-b border-midnight-600/50 text-gray-500 text-xs uppercase tracking-wider">
          <th class="py-3 px-4">Quest</th>
          <th class="py-3 px-4 hidden sm:table-cell">Zone</th>
          <th class="py-3 px-4 hidden md:table-cell">Quest Line</th>
          <th class="py-3 px-4 hidden md:table-cell">Type</th>
          <th class="py-3 px-4">Level</th>
        </tr>
      </thead>
      <tbody id="quest-tbody" class="text-sm"></tbody>
    </table>
  </div>

  <div id="quest-detail" class="hidden mt-6 bg-midnight-700/50 border border-midnight-600/50 rounded-xl p-6"></div>
</div>

<script>
  interface Quest {
    id: number;
    title: string;
    description: string;
    zone: string;
    questLineName: string;
    level?: number;
    flags: { isCampaign: boolean; isLocalStory: boolean; isImportant: boolean };
    objectives: { description: string; amount: number }[];
    rewards: { xp?: number; gold?: number; items?: { name: string; quantity: number }[] };
    acceptNpcName?: string;
    turnInNpcName?: string;
    prerequisites: number[];
  }

  let allQuests: Quest[] = [];

  const searchInput = document.getElementById('quest-search') as HTMLInputElement;
  const zoneFilter = document.getElementById('quest-zone-filter') as HTMLSelectElement;
  const typeFilter = document.getElementById('quest-type-filter') as HTMLSelectElement;
  const tbody = document.getElementById('quest-tbody')!;
  const countEl = document.getElementById('quest-count')!;
  const detailEl = document.getElementById('quest-detail')!;

  const base = document.getElementById('quest-table-app')!.dataset.base || '';

  async function loadQuests() {
    const res = await fetch(`${base}data/quests.json`);
    allQuests = await res.json();
    render();
  }

  function getTypeLabel(q: Quest): string {
    if (q.flags.isCampaign) return 'Campaign';
    if (q.flags.isLocalStory) return 'Side Story';
    if (q.flags.isImportant) return 'Important';
    return '';
  }

  function getTypeBadgeClass(q: Quest): string {
    if (q.flags.isCampaign) return 'bg-gold-400/15 text-gold-400 border border-gold-400/20';
    if (q.flags.isLocalStory) return 'bg-arcane-400/15 text-arcane-400 border border-arcane-400/20';
    if (q.flags.isImportant) return 'bg-blue-400/15 text-blue-400 border border-blue-400/20';
    return 'bg-gray-600/15 text-gray-500 border border-gray-600/20';
  }

  function matchesFilters(q: Quest): boolean {
    const search = searchInput.value.toLowerCase();
    if (search && !q.title.toLowerCase().includes(search) && !q.questLineName.toLowerCase().includes(search)) {
      return false;
    }
    const zone = zoneFilter.value;
    if (zone && q.zone !== zone) return false;
    const type = typeFilter.value;
    if (type === 'campaign' && !q.flags.isCampaign) return false;
    if (type === 'sidestory' && !q.flags.isLocalStory) return false;
    if (type === 'important' && !q.flags.isImportant) return false;
    return true;
  }

  function render() {
    const filtered = allQuests.filter(matchesFilters);
    countEl.textContent = `Showing ${filtered.length} of ${allQuests.length} quests`;

    tbody.innerHTML = filtered.slice(0, 100).map(q => `
      <tr class="border-b border-midnight-600/20 hover:bg-midnight-700/30 cursor-pointer quest-row transition-colors" data-id="${q.id}">
        <td class="py-3 px-4">
          <span class="text-white">${q.title}</span>
          <span class="text-gray-600 text-xs ml-1.5">#${q.id}</span>
        </td>
        <td class="py-3 px-4 text-gray-500 hidden sm:table-cell">${q.zone}</td>
        <td class="py-3 px-4 text-gray-500 hidden md:table-cell">${q.questLineName}</td>
        <td class="py-3 px-4 hidden md:table-cell">
          ${getTypeLabel(q) ? `<span class="text-xs px-2 py-0.5 rounded-md ${getTypeBadgeClass(q)}">${getTypeLabel(q)}</span>` : ''}
        </td>
        <td class="py-3 px-4 text-gray-500">${q.level ?? ''}</td>
      </tr>
    `).join('');

    if (filtered.length > 100) {
      tbody.innerHTML += `<tr><td colspan="5" class="py-6 text-center text-gray-600 text-sm">Showing first 100 of ${filtered.length} results. Refine your search to see more.</td></tr>`;
    }

    // Add click handlers
    tbody.querySelectorAll('.quest-row').forEach(row => {
      row.addEventListener('click', () => showDetail(Number(row.getAttribute('data-id'))));
    });
  }

  function showDetail(questId: number) {
    const q = allQuests.find(q => q.id === questId);
    if (!q) return;

    const zoneKey = { 'Eversong Woods': 'eversong', "Zul'Aman": 'zulaman', 'Harandar': 'harandar', 'Voidstorm': 'voidstorm' }[q.zone] ?? '';

    detailEl.innerHTML = `
      <div class="flex justify-between items-start mb-4">
        <div>
          <h3 class="text-xl font-semibold text-white">${q.title}</h3>
          <p class="text-gray-500 text-sm mt-1">${q.questLineName} &middot; ${q.zone} &middot; Level ${q.level ?? '?'}</p>
        </div>
        <button id="close-detail" class="text-gray-600 hover:text-white text-xl transition-colors">&times;</button>
      </div>
      <p class="text-gray-400 text-sm mb-4 leading-relaxed">${q.description.replace(/\r\n/g, '<br>')}</p>
      ${q.objectives.length ? `
        <div class="mb-4">
          <h4 class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Objectives</h4>
          <ul class="text-sm text-gray-300 space-y-1">
            ${q.objectives.map(o => `<li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-gold-400 rounded-full shrink-0"></span>${o.description}${o.amount > 1 ? ` (${o.amount})` : ''}</li>`).join('')}
          </ul>
        </div>
      ` : ''}
      <div class="flex flex-wrap gap-4 text-sm text-gray-500">
        ${q.acceptNpcName ? `<span>Accept: <span class="text-gray-300">${q.acceptNpcName}</span></span>` : ''}
        ${q.turnInNpcName ? `<span>Turn in: <span class="text-gray-300">${q.turnInNpcName}</span></span>` : ''}
        ${q.rewards.xp ? `<span>XP: <span class="text-gray-300">${q.rewards.xp.toLocaleString()}</span></span>` : ''}
        ${q.rewards.gold ? `<span>Gold: <span class="text-gray-300">${(q.rewards.gold / 10000).toFixed(1)}g</span></span>` : ''}
      </div>
      ${zoneKey ? `<a href="${base}map/${zoneKey}" class="inline-block mt-4 text-sm text-arcane-400 hover:text-arcane-300 transition-colors">View on map &rarr;</a>` : ''}
    `;
    detailEl.classList.remove('hidden');
    detailEl.querySelector('#close-detail')?.addEventListener('click', () => detailEl.classList.add('hidden'));
  }

  searchInput.addEventListener('input', render);
  zoneFilter.addEventListener('change', render);
  typeFilter.addEventListener('change', render);

  loadQuests();
</script>

---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const links = [
  { href: `${base}`, label: 'Home' },
  { href: `${base}map/voidstorm`, label: 'Maps' },
  { href: `${base}quests`, label: 'Quests' },
  { href: `${base}stats`, label: 'Stats' },
  { href: `${base}download`, label: 'Download' },
];
---

<nav class="bg-midnight-800 border-b border-midnight-600">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href={base} class="flex items-center gap-2 text-gold-400 font-bold text-xl">
        OpenQuest
      </a>
      <div class="hidden md:flex items-center gap-6">
        {links.map(link => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-gold-400'
                : 'text-gray-300 hover:text-white',
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>
      <button id="mobile-menu-btn" class="md:hidden text-gray-300 hover:text-white" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  <div id="mobile-menu" class="hidden md:hidden border-t border-midnight-600">
    <div class="px-4 py-3 space-y-2">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            'block text-sm font-medium py-1',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-gold-400'
              : 'text-gray-300 hover:text-white',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>

---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const links = [
  { href: `${base}`, label: 'Home' },
  { href: `${base}map/voidstorm`, label: 'Maps' },
  { href: `${base}quests`, label: 'Quests' },
  { href: `${base}stats`, label: 'Stats' },
  { href: `${base}download`, label: 'Download' },
];
---

<nav class="bg-midnight-800/80 backdrop-blur-md border-b border-midnight-600/50 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href={base} class="flex items-center gap-2.5 group">
        <div class="w-8 h-8 bg-gradient-to-br from-gold-400 to-gold-500 rounded-lg flex items-center justify-center shadow-lg shadow-gold-400/20 group-hover:shadow-gold-400/40 transition-shadow">
          <span class="text-midnight-900 font-black text-sm">Q</span>
        </div>
        <span class="text-white font-bold text-lg">Open<span class="text-gold-400">Quest</span></span>
      </a>
      <div class="hidden md:flex items-center gap-1">
        {links.map(link => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium px-3 py-1.5 rounded-lg transition-all',
              currentPath === link.href || (link.href !== base && currentPath.startsWith(link.href))
                ? 'text-gold-400 bg-gold-400/10'
                : 'text-gray-400 hover:text-white hover:bg-midnight-700/50',
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>
      <button id="mobile-menu-btn" class="md:hidden text-gray-300 hover:text-white p-2 rounded-lg hover:bg-midnight-700/50 transition-colors" aria-label="Toggle menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  <div id="mobile-menu" class="hidden md:hidden border-t border-midnight-600/50 bg-midnight-800/95 backdrop-blur-md">
    <div class="px-4 py-3 space-y-1">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            'block text-sm font-medium py-2 px-3 rounded-lg transition-colors',
            currentPath === link.href || (link.href !== base && currentPath.startsWith(link.href))
              ? 'text-gold-400 bg-gold-400/10'
              : 'text-gray-300 hover:text-white hover:bg-midnight-700/50',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>

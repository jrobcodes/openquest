---
interface Props {
  zoneKey: string;
  zoneName: string;
}

const { zoneKey, zoneName } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<div id="zone-map-app" data-zone-key={zoneKey} data-zone-name={zoneName} data-base={base}>
  <div class="flex flex-col lg:flex-row gap-4 h-[calc(100vh-11rem)]">
    <!-- Map -->
    <div class="flex-1 relative">
      <div id="map" class="w-full h-full rounded-xl border border-midnight-600/50 bg-midnight-800"></div>
      <!-- Filters -->
      <div class="absolute top-3 right-3 z-[1000] bg-midnight-800/95 backdrop-blur-sm border border-midnight-600/50 rounded-xl p-3 space-y-2 text-sm shadow-lg">
        <label class="flex items-center gap-2 text-gray-300 cursor-pointer hover:text-white transition-colors">
          <input type="checkbox" id="filter-campaign" checked class="accent-gold-400 rounded" />
          <span class="w-2 h-2 bg-green-500 rounded-full"></span>
          Campaign
        </label>
        <label class="flex items-center gap-2 text-gray-300 cursor-pointer hover:text-white transition-colors">
          <input type="checkbox" id="filter-side" checked class="accent-arcane-400 rounded" />
          <span class="w-2 h-2 bg-blue-400 rounded-full"></span>
          Side Quests
        </label>
        <label class="flex items-center gap-2 text-gray-300 cursor-pointer hover:text-white transition-colors">
          <input type="checkbox" id="filter-extras" checked class="accent-purple-400 rounded" />
          <span class="w-2 h-2 bg-purple-400 rounded-full"></span>
          Extras
        </label>
        <div class="border-t border-midnight-600/50 pt-2">
          <label class="flex items-center gap-2 text-gray-400 cursor-pointer hover:text-white transition-colors">
            <input type="checkbox" id="filter-route" checked class="accent-gray-400 rounded" />
            Route Lines
          </label>
        </div>
      </div>
    </div>

    <!-- Step list sidebar -->
    <div class="lg:w-80 h-64 lg:h-full overflow-y-auto bg-midnight-800/60 border border-midnight-600/50 rounded-xl">
      <div class="sticky top-0 bg-midnight-800 p-3.5 border-b border-midnight-600/50 z-10">
        <h3 class="text-white font-semibold text-sm">Route Steps</h3>
        <p id="step-count" class="text-gray-600 text-xs mt-0.5"></p>
      </div>
      <div id="step-list" class="p-2 space-y-0.5"></div>
    </div>
  </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script is:inline>
  (function() {
    var app = document.getElementById('zone-map-app');
    if (!app) return;
    var zoneName = app.dataset.zoneName;
    var zoneKey = app.dataset.zoneKey;
    var base = app.dataset.base || '';

    var actionColors = {
      accept: '#22c55e',
      turnin: '#3b82f6',
      objective: '#eab308',
      collect: '#a855f7',
      travel: '#6b7280',
    };

    var actionIcons = {
      accept: '!',
      turnin: '?',
      objective: '*',
      collect: '+',
      travel: '>',
    };

    // Image is 3840x2560 -> aspect ratio 1.5:1
    var imgW = 1.5;
    var imgH = 1;
    var bounds = [[0, 0], [imgH, imgW]];

    var map = L.map('map', {
      crs: L.CRS.Simple,
      minZoom: 0,
      maxZoom: 4,
      zoomSnap: 0.5,
      maxBounds: [[-0.1, -0.1], [imgH + 0.1, imgW + 0.1]],
    });

    map.fitBounds(bounds);

    var imageUrl = base + 'maps/' + zoneKey + '.png';
    L.imageOverlay(imageUrl, bounds).addTo(map);

    var allSteps = [];
    var markers = [];
    var routeLine = null;

    function loadData() {
      fetch(base + 'data/guide-full.json')
        .then(function(res) { return res.json(); })
        .then(function(guide) {
          allSteps = guide.filter(function(s) {
            return s.zone === zoneName && s.mapX != null && s.mapY != null;
          });
          render();
        });
    }

    function shouldShow(step) {
      var showCampaign = document.getElementById('filter-campaign').checked;
      var showSide = document.getElementById('filter-side').checked;
      var showExtras = document.getElementById('filter-extras').checked;

      if (step.extraType) return showExtras;
      if (step.isCampaign) return showCampaign;
      return showSide;
    }

    function render() {
      markers.forEach(function(m) { m.remove(); });
      markers = [];
      if (routeLine) { routeLine.remove(); routeLine = null; }

      var filtered = allSteps.filter(shouldShow);
      var showRoute = document.getElementById('filter-route').checked;

      // Route line — mapX/mapY are 0-1 normalized, scale to image bounds
      if (showRoute && filtered.length > 1) {
        var points = filtered.map(function(s) {
          return [(1 - s.mapY) * imgH, s.mapX * imgW];
        });
        routeLine = L.polyline(points, {
          color: '#6b7280',
          weight: 1.5,
          opacity: 0.4,
          dashArray: '4 4',
        }).addTo(map);
      }

      // Markers
      filtered.forEach(function(step) {
        var color = actionColors[step.action] || '#6b7280';
        var latlng = [(1 - step.mapY) * imgH, step.mapX * imgW];
        var marker = L.circleMarker(latlng, {
          radius: 5,
          fillColor: color,
          color: '#000',
          weight: 1,
          fillOpacity: 0.9,
        }).addTo(map);

        marker.bindPopup(
          '<div style="min-width:160px">' +
            '<strong style="color:#fff">' + step.description + '</strong><br/>' +
            '<span style="color:#9ca3af;font-size:12px">Step ' + step.stepNumber + '</span>' +
            (step.npcName ? '<br/><span style="color:#9ca3af;font-size:12px">NPC: ' + step.npcName + '</span>' : '') +
            (step.questTitle ? '<br/><span style="color:#a78bfa;font-size:12px">' + step.questTitle + '</span>' : '') +
          '</div>'
        );

        markers.push(marker);
      });

      // Step list
      var stepList = document.getElementById('step-list');
      var stepCount = document.getElementById('step-count');
      stepCount.textContent = filtered.length + ' steps';

      stepList.innerHTML = filtered.map(function(step, i) {
        var color = actionColors[step.action] || '#6b7280';
        var icon = actionIcons[step.action] || '?';
        return '<button class="step-item w-full text-left px-2.5 py-2 rounded-lg text-xs hover:bg-midnight-700/60 transition-colors flex items-center gap-2.5" data-index="' + i + '">' +
          '<span class="w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold shrink-0" style="background:' + color + ';color:#000">' + icon + '</span>' +
          '<span class="text-gray-400 truncate">' + step.description + '</span>' +
        '</button>';
      }).join('');

      // Click step -> pan to marker
      stepList.querySelectorAll('.step-item').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var idx = Number(btn.getAttribute('data-index'));
          var step = filtered[idx];
          if (step && markers[idx]) {
            map.setView([(1 - step.mapY) * imgH, step.mapX * imgW], 3);
            markers[idx].openPopup();
          }
        });
      });
    }

    // Filter change handlers
    ['filter-campaign', 'filter-side', 'filter-extras', 'filter-route'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) el.addEventListener('change', render);
    });

    loadData();
  })();
</script>

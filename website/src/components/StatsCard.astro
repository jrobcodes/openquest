---
interface Props {
  label: string;
  value: string | number;
  sublabel?: string;
}

const { label, value, sublabel } = Astro.props;
---

<div class="bg-midnight-700 rounded-lg p-6 border border-midnight-600">
  <p class="text-gray-400 text-sm">{label}</p>
  <p class="text-3xl font-bold text-white mt-1">{value}</p>
  {sublabel && <p class="text-gray-500 text-xs mt-1">{sublabel}</p>}
</div>

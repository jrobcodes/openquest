---
interface Props {
  label: string;
  value: string | number;
  sublabel?: string;
  accent?: 'gold' | 'arcane' | 'default';
}

const { label, value, sublabel, accent = 'default' } = Astro.props;

const accentClasses = {
  gold: 'border-gold-400/20 hover:border-gold-400/40',
  arcane: 'border-arcane-400/20 hover:border-arcane-400/40',
  default: 'border-midnight-600/50 hover:border-midnight-500',
};

const valueClasses = {
  gold: 'text-gold-400',
  arcane: 'text-arcane-400',
  default: 'text-white',
};
---

<div class:list={['bg-midnight-700/50 rounded-xl p-6 border transition-colors', accentClasses[accent]]}>
  <p class="text-gray-500 text-sm font-medium">{label}</p>
  <p class:list={['text-3xl font-bold mt-1.5', valueClasses[accent]]}>{value}</p>
  {sublabel && <p class="text-gray-600 text-xs mt-1.5">{sublabel}</p>}
</div>

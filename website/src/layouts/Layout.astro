---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Free, algorithmically-optimized WoW questing guide for Midnight' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" class="bg-midnight-900 text-gray-100">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title} | OpenQuest</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <footer class="border-t border-midnight-600/30 py-8 mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="text-gray-600 text-sm">
            OpenQuest is a free, open-source WoW questing guide. Not affiliated with Blizzard Entertainment.
          </p>
          <div class="flex items-center gap-6">
            <a
              href="https://github.com/jrobcodes/openquest"
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-500 hover:text-white text-sm transition-colors"
            >
              GitHub
            </a>
            <a
              href="https://www.patreon.com/c/openquest"
              target="_blank"
              rel="noopener noreferrer"
              class="text-gold-400 hover:text-gold-300 text-sm font-medium transition-colors"
            >
              Support on Patreon
            </a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

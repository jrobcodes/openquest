---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Download">
  <div class="max-w-3xl mx-auto py-16 px-4">
    <h1 class="text-4xl font-bold text-white mb-2">Download OpenQuest</h1>
    <p class="text-gray-500 mb-10">Get the addon and start questing with optimized routes.</p>

    <!-- Download Links -->
    <div class="bg-midnight-700/50 border border-midnight-600/50 rounded-xl p-8 mb-6">
      <h2 class="text-xl font-semibold text-white mb-4">Get the Addon</h2>
      <a
        href="https://github.com/jrobcodes/openquest/releases/latest"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-between bg-midnight-800/60 hover:bg-midnight-600/40 border border-midnight-600/50 hover:border-gold-400/30 rounded-xl p-5 transition-all group"
      >
        <div>
          <p class="text-white font-medium group-hover:text-gold-400 transition-colors">GitHub Releases</p>
          <p class="text-gray-500 text-sm mt-0.5">Download the latest .zip from GitHub</p>
        </div>
        <span class="text-gray-600 group-hover:text-gold-400 text-xl transition-colors">&rarr;</span>
      </a>
    </div>

    <!-- Install Instructions -->
    <div class="bg-midnight-700/50 border border-midnight-600/50 rounded-xl p-8 mb-6">
      <h2 class="text-xl font-semibold text-white mb-6">Installation</h2>
      <ol class="space-y-5 text-gray-300">
        <li class="flex gap-4">
          <span class="w-7 h-7 bg-gold-400/10 text-gold-400 rounded-lg flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">1</span>
          <div>
            <p>Download the latest release <code class="bg-midnight-800/80 border border-midnight-600/30 px-2 py-0.5 rounded text-sm text-gray-400">OpenQuest-x.x.x.zip</code></p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="w-7 h-7 bg-gold-400/10 text-gold-400 rounded-lg flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">2</span>
          <div>
            <p>Extract the zip file</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="w-7 h-7 bg-gold-400/10 text-gold-400 rounded-lg flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">3</span>
          <div>
            <p>Copy the <code class="bg-midnight-800/80 border border-midnight-600/30 px-2 py-0.5 rounded text-sm text-gray-400">OpenQuest</code> folder into your WoW addons directory:</p>
            <code class="block bg-midnight-900/60 border border-midnight-600/30 mt-3 p-4 rounded-lg text-sm text-gray-500 overflow-x-auto">
              World of Warcraft/_retail_/Interface/AddOns/OpenQuest
            </code>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="w-7 h-7 bg-gold-400/10 text-gold-400 rounded-lg flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">4</span>
          <p>Restart WoW or type <code class="bg-midnight-800/80 border border-midnight-600/30 px-2 py-0.5 rounded text-sm text-gray-400">/reload</code> in-game</p>
        </li>
      </ol>
    </div>

    <!-- Dependencies -->
    <div class="bg-midnight-700/50 border border-midnight-600/50 rounded-xl p-8">
      <h2 class="text-xl font-semibold text-white mb-4">Optional Dependencies</h2>
      <div class="flex items-start gap-4 text-gray-300">
        <div class="w-10 h-10 bg-arcane-400/10 rounded-xl flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-arcane-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <div>
          <p class="font-medium text-white">TomTom</p>
          <p class="text-sm text-gray-500 mt-0.5">
            For in-game waypoint arrows. OpenQuest sets TomTom waypoints automatically when installed.
            Available on CurseForge.
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>

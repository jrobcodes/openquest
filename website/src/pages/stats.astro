---
import Layout from '../layouts/Layout.astro';
import StatsCard from '../components/StatsCard.astro';
import { zones, zoneNameToKey } from '../lib/map-config';
import fs from 'node:fs';
import path from 'node:path';
const base = import.meta.env.BASE_URL;

const dataDir = path.join(process.cwd(), 'public/data');

let guideStats: any = {};
let stats: any = {};

try {
  guideStats = JSON.parse(fs.readFileSync(path.join(dataDir, 'guide-full-stats.json'), 'utf-8'));
  stats = JSON.parse(fs.readFileSync(path.join(dataDir, 'stats.json'), 'utf-8'));
} catch {
  // Data not synced yet
}

const totalQuests = stats.totalQuests ?? 0;
const totalExtras = stats.totalExtras ?? 0;
const campaignQuests = stats.campaignQuests ?? 0;
const sideStoryQuests = stats.sideStoryQuests ?? 0;
const questLines = stats.questLines ?? [];
const distanceSavings = guideStats.vsNaivePct ?? 0;
const totalSteps = guideStats.totalSteps ?? 0;
const glyphs = guideStats.extras?.glyphs ?? 0;
const treasures = guideStats.extras?.treasures ?? 0;
const rares = guideStats.extras?.rares ?? 0;
---

<Layout title="Stats">
  <div class="max-w-6xl mx-auto py-16 px-4">
    <h1 class="text-4xl font-bold text-white mb-2">Route Statistics</h1>
    <p class="text-gray-500 mb-12">Performance metrics from the OpenQuest route optimizer.</p>

    <!-- Key Metrics -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
      <StatsCard label="Distance Savings" value={`${distanceSavings}%`} sublabel="vs naive ordering" accent="gold" />
      <StatsCard label="Total Quests" value={totalQuests} />
      <StatsCard label="Total Steps" value={totalSteps.toLocaleString()} />
      <StatsCard label="Extras" value={totalExtras} sublabel={`${glyphs} glyphs, ${treasures} treasures, ${rares} rares`} accent="arcane" />
    </div>

    <!-- Quest Breakdown -->
    <div class="grid md:grid-cols-2 gap-6 mb-12">
      <div class="bg-midnight-700/50 border border-midnight-600/50 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-white mb-5">Quest Types</h2>
        <div class="space-y-4">
          <div>
            <div class="flex justify-between items-center mb-1.5">
              <span class="text-gray-300 text-sm">Campaign</span>
              <span class="text-gold-400 font-semibold text-sm">{campaignQuests}</span>
            </div>
            <div class="w-full bg-midnight-800 rounded-full h-2">
              <div class="bg-gradient-to-r from-gold-400 to-gold-500 h-2 rounded-full transition-all" style={`width: ${(campaignQuests / totalQuests * 100).toFixed(0)}%`}></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between items-center mb-1.5">
              <span class="text-gray-300 text-sm">Side Stories</span>
              <span class="text-arcane-400 font-semibold text-sm">{sideStoryQuests}</span>
            </div>
            <div class="w-full bg-midnight-800 rounded-full h-2">
              <div class="bg-gradient-to-r from-arcane-400 to-arcane-500 h-2 rounded-full transition-all" style={`width: ${(sideStoryQuests / totalQuests * 100).toFixed(0)}%`}></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between items-center mb-1.5">
              <span class="text-gray-300 text-sm">Other</span>
              <span class="text-gray-400 font-semibold text-sm">{totalQuests - campaignQuests - sideStoryQuests}</span>
            </div>
            <div class="w-full bg-midnight-800 rounded-full h-2">
              <div class="bg-gradient-to-r from-gray-500 to-gray-600 h-2 rounded-full transition-all" style={`width: ${((totalQuests - campaignQuests - sideStoryQuests) / totalQuests * 100).toFixed(0)}%`}></div>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-midnight-700/50 border border-midnight-600/50 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-white mb-5">Zones</h2>
        <div class="space-y-2">
          {(guideStats.zones ?? []).map((zoneName: string) => (
            <a
              href={`${base}map/${zoneNameToKey[zoneName] ?? zoneName.toLowerCase()}`}
              class="flex justify-between items-center py-2.5 px-3 rounded-lg hover:bg-midnight-600/40 transition-colors group"
            >
              <span class="text-gray-300 group-hover:text-white transition-colors">{zoneName}</span>
              <span class="text-gray-600 group-hover:text-arcane-400 transition-colors">&rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Quest Lines -->
    <div class="bg-midnight-700/50 border border-midnight-600/50 rounded-xl p-6">
      <h2 class="text-lg font-semibold text-white mb-5">Quest Lines <span class="text-gray-500 font-normal">({questLines.length})</span></h2>
      <div class="flex flex-wrap gap-2">
        {questLines.map((ql: string) => (
          <span class="bg-midnight-800/80 text-gray-400 text-xs px-3 py-1.5 rounded-lg border border-midnight-600/30 hover:text-gray-300 hover:border-midnight-500 transition-colors">{ql}</span>
        ))}
      </div>
    </div>
  </div>
</Layout>

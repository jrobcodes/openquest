---
import Layout from '../../layouts/Layout.astro';
import ZoneMap from '../../components/ZoneMap.astro';
import { zones, zoneKeyToName } from '../../lib/map-config';

export function getStaticPaths() {
  return zones.map(z => ({
    params: { zone: z.key },
    props: { zoneName: z.name },
  }));
}

const { zone } = Astro.params;
const { zoneName } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Layout title={`${zoneName} Map`}>
  <div class="max-w-7xl mx-auto py-6 px-4">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-5 gap-4">
      <div>
        <h1 class="text-2xl font-bold text-white">{zoneName}</h1>
        <p class="text-gray-500 text-sm mt-0.5">Interactive route map with quest and extra markers</p>
      </div>
      <div class="flex gap-1.5 bg-midnight-800/60 border border-midnight-600/50 rounded-lg p-1">
        {zones.map(z => (
          <a
            href={`${base}map/${z.key}`}
            class:list={[
              'text-sm px-3 py-1.5 rounded-md transition-all font-medium',
              z.key === zone
                ? 'bg-arcane-400/15 text-arcane-400 shadow-sm'
                : 'text-gray-500 hover:text-gray-300 hover:bg-midnight-700/50',
            ]}
          >
            {z.name}
          </a>
        ))}
      </div>
    </div>
    <ZoneMap zoneKey={zone!} zoneName={zoneName} />
  </div>
</Layout>

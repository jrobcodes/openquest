---
import Layout from '../../layouts/Layout.astro';
import ZoneMap from '../../components/ZoneMap.astro';
import { zones, zoneKeyToName } from '../../lib/map-config';

export function getStaticPaths() {
  return zones.map(z => ({
    params: { zone: z.key },
    props: { zoneName: z.name },
  }));
}

const { zone } = Astro.params;
const { zoneName } = Astro.props;
---

<Layout title={`${zoneName} Map`}>
  <div class="max-w-7xl mx-auto py-8 px-4">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-3xl font-bold text-white">{zoneName}</h1>
        <p class="text-gray-400 text-sm mt-1">Interactive route map with quest and extra markers</p>
      </div>
      <div class="flex gap-2">
        {zones.map(z => (
          <a
            href={`/map/${z.key}`}
            class:list={[
              'text-sm px-3 py-1.5 rounded-lg border transition-colors',
              z.key === zone
                ? 'border-arcane-400 text-arcane-400 bg-arcane-400/10'
                : 'border-midnight-600 text-gray-400 hover:text-white hover:border-gray-400',
            ]}
          >
            {z.name}
          </a>
        ))}
      </div>
    </div>
    <ZoneMap zoneKey={zone!} zoneName={zoneName} />
  </div>
</Layout>

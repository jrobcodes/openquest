---
import Layout from '../layouts/Layout.astro';
import { zones } from '../lib/map-config';
const base = import.meta.env.BASE_URL;
---

<Layout title="Home">
  <!-- Hero -->
  <section class="relative py-24 px-4 text-center overflow-hidden">
    <!-- Background glow -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-arcane-400/8 rounded-full blur-[100px]"></div>
      <div class="absolute top-1/3 left-1/3 w-[300px] h-[300px] bg-gold-400/5 rounded-full blur-[80px]"></div>
    </div>

    <div class="max-w-4xl mx-auto relative">
      <div class="inline-flex items-center gap-2 bg-midnight-700/60 border border-midnight-600/50 rounded-full px-4 py-1.5 text-sm text-gray-400 mb-8">
        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
        Midnight expansion supported
      </div>

      <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 tracking-tight">
        Open<span class="text-transparent bg-clip-text bg-gradient-to-r from-gold-300 to-gold-500">Quest</span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 mb-3 font-light">
        Free, algorithmically-optimized WoW questing guide
      </p>
      <p class="text-gray-500 mb-10 max-w-2xl mx-auto">
        Route every quest in Midnight with 24.8% less travel distance than naive ordering.
        Campaign, side stories, glyphs, treasures, and rares &mdash; all optimized.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`${base}download`}
          class="group bg-gradient-to-r from-gold-400 to-gold-500 hover:from-gold-300 hover:to-gold-400 text-midnight-900 font-bold py-3.5 px-8 rounded-xl transition-all text-lg shadow-lg shadow-gold-400/20 hover:shadow-gold-400/30"
        >
          Download Addon
          <span class="inline-block ml-1 group-hover:translate-x-0.5 transition-transform">&rarr;</span>
        </a>
        <a
          href={`${base}map/voidstorm`}
          class="border border-arcane-400/50 text-arcane-400 hover:bg-arcane-400/10 hover:border-arcane-400 font-medium py-3.5 px-8 rounded-xl transition-all text-lg"
        >
          View Maps
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 px-4 border-t border-midnight-600/30">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-white text-center mb-4">Why OpenQuest?</h2>
      <p class="text-gray-500 text-center mb-14 max-w-xl mx-auto">Built different from traditional step-by-step guides.</p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-midnight-700/50 border border-midnight-600/50 rounded-xl p-8 hover:border-gold-400/30 transition-colors group">
          <div class="w-12 h-12 bg-gold-400/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-gold-400/20 transition-colors">
            <svg class="w-6 h-6 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">Optimized Routes</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            DAG-based dependency solver with nearest-neighbor heuristics minimizes backtracking across all 4 Midnight zones.
          </p>
        </div>
        <div class="bg-midnight-700/50 border border-midnight-600/50 rounded-xl p-8 hover:border-arcane-400/30 transition-colors group">
          <div class="w-12 h-12 bg-arcane-400/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-arcane-400/20 transition-colors">
            <svg class="w-6 h-6 text-arcane-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">Auto-Advance</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            In-game addon tracks quest progress and automatically advances to the next step. Just follow the arrow.
          </p>
        </div>
        <div class="bg-midnight-700/50 border border-midnight-600/50 rounded-xl p-8 hover:border-blue-400/30 transition-colors group">
          <div class="w-12 h-12 bg-blue-400/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-blue-400/20 transition-colors">
            <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">Extras Included</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Glyphs, treasures, and rare mobs inserted along your route via cheapest-insertion so you never go out of your way.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Zone Cards -->
  <section class="py-20 px-4 border-t border-midnight-600/30">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-white text-center mb-4">Explore Zones</h2>
      <p class="text-gray-500 text-center mb-14">Click a zone to view the interactive route map.</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        {zones.map(zone => (
          <a
            href={`${base}map/${zone.key}`}
            class="group relative bg-midnight-700/50 border border-midnight-600/50 rounded-xl p-6 hover:border-arcane-400/40 transition-all hover:-translate-y-0.5"
          >
            <div class="absolute inset-0 bg-gradient-to-br from-arcane-400/0 to-arcane-400/5 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative">
              <h3 class="text-lg font-semibold text-white group-hover:text-arcane-300 transition-colors">
                {zone.name}
              </h3>
              <p class="text-gray-500 text-sm mt-1">View interactive route map</p>
              <span class="text-arcane-400 text-sm mt-3 inline-block opacity-0 group-hover:opacity-100 transition-opacity">&rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
